# ------------------------------------------------------------------
# Libertas — environment variables
# Copy this file to `.env.local` for local development, and add the
# same keys in your Vercel Project → Settings → Environment Variables.
# ------------------------------------------------------------------

# Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=

# Inbox that receives contact-form enquiries
CONTACT_EMAIL=hello@libertas.com

# The "from" address for outgoing mail. Must be on a domain you have
# verified in Resend (https://resend.com/domains). Optional — defaults
# to "Libertas <noreply@libertas.com>".
CONTACT_FROM="Libertas <noreply@libertas.com>"

# Public site URL — used for metadata, canonical URL, sitemap & robots
NEXT_PUBLIC_SITE_URL=https://libertas.com
